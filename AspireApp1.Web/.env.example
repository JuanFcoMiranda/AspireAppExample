VITE_API_BASE_URL=http://localhost:51270

# OpenTelemetry / Aspire Configuration
# El endpoint OTLP donde Aspire Dashboard escucha las trazas
# Por defecto Aspire usa el puerto 4317 para gRPC o 4318 para HTTP/Protobuf
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Nombre del servicio para identificarlo en Aspire Dashboard
VITE_OTEL_SERVICE_NAME=aspireapp1-web

# Versión del servicio
VITE_OTEL_SERVICE_VERSION=0.1.0

